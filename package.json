{
  "name": "remix-template-remix-ts",
  "private": true,
  "description": "",
  "license": "",
  "sideEffects": false,
  "scripts": {
    "build": "run-s build:*",
    "build:css": "npm run generate:css -- --minify",
    "build:remix": "remix build",
    "build:server": "esbuild --platform=node --format=cjs ./server.ts --outdir=build",
    "format": "prettier --write .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "dev:serverBuild": "cross-env NODE_ENV=development npm run build:server -- --watch",
    "dev:remix": "remix watch",
    "dev:tailwind": "npm run generate:css -- --minify",
    "dev:server": "nodemon --inspect --require ./node_modules/dotenv/config --require ./mocks ./build/server.js",
    "dev": "run-p dev:*",
    "generate:css": "npx tailwindcss -i ./app/styles/tailwind.css -o ./app/tailwind.css",
    "postinstall": "remix setup node",
    "start": "cross-env NODE_ENV=production node ./build/server.js",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@node-rs/bcrypt": "^1.6.0",
    "@prisma/client": "^3.11.0",
    "@remix-run/express": "^1.3.2",
    "@remix-run/react": "^1.3.2",
    "compression": "^1.7.4",
    "cross-env": "^7.0.3",
    "express": "^4.17.3",
    "morgan": "^1.10.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "remix": "^1.3.2",
    "tiny-invariant": "^1.2.0"
  },
  "devDependencies": {
    "@headlessui/react": "^1.5.0",
    "@heroicons/react": "^1.0.6",
    "@remix-run/dev": "^1.3.2",
    "@remix-run/eslint-config": "^1.3.2",
    "@tailwindcss/forms": "^0.5.0",
    "@types/compression": "^1.7.2",
    "@types/eslint": "^8.4.1",
    "@types/express": "^4.17.13",
    "@types/morgan": "^1.9.3",
    "@types/react": "^17.0.24",
    "@types/react-dom": "^17.0.9",
    "dotenv": "^16.0.0",
    "esbuild": "^0.14.27",
    "esbuild-register": "^3.3.2",
    "eslint": "^8.11.0",
    "eslint-config-prettier": "^8.5.0",
    "msw": "^0.39.2",
    "nodemon": "^2.0.15",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.0",
    "prettier-plugin-tailwindcss": "^0.1.8",
    "prisma": "^3.11.0",
    "tailwindcss": "^3.0.23",
    "typescript": "^4.5.5"
  },
  "prettier": {},
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "engines": {
    "node": ">=14"
  }
}
